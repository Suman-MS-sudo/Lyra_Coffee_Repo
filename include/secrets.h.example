#pragma once

// ================================================================
//  Lyra Machine — Secrets (per-device)
//  Copy this file to `secrets.h` in the same folder and fill in.
//  `secrets.h` is git-ignored so each unit can carry its own keys.
// ================================================================

// ── Wi-Fi ───────────────────────────────────────────────────────
#define WIFI_SSID       "your-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

// ── Server identity ─────────────────────────────────────────────
//   * MACHINE_ID    : the UUID shown in the admin "Created" dialog
//   * MACHINE_KEY   : the plaintext API key shown ONCE on creation
//   * SERVER_HOST   : your deployed Lyra hostname (no scheme, no slash)
#define MACHINE_ID      "00000000-0000-0000-0000-000000000000"
#define MACHINE_KEY     "paste-the-api-key-shown-on-creation"
#define SERVER_HOST     "brew.lyra-app.co.in"
#define SERVER_PORT     443     // 443 for HTTPS, 80 for plain HTTP
#define USE_HTTPS       1       // 1 = WiFiClientSecure, 0 = WiFiClient
