#pragma once

// ================================================================
//  Lyra Machine — Compile-time defaults (identical for every unit)
//  Copy this file to `secrets.h` in the same folder and edit.
//  `secrets.h` is git-ignored.
//
//  NOTE: Per-device identity (machine UUID + API key) is NO LONGER
//  configured here. The firmware reads its own MAC address at boot
//  and pulls its identity from the server via /api/machine/identify.
//  Just register the machine in the admin UI with the correct MAC.
// ================================================================

// ── Server identity ─────────────────────────────────────────────
#define SERVER_HOST     "brew.lyra-app.co.in"
#define SERVER_PORT     443     // 443 for HTTPS, 80 for plain HTTP
#define USE_HTTPS       1       // 1 = WiFiClientSecure, 0 = WiFiClient

// ── Wi-Fi defaults (optional — captive portal can override) ─────
//   These only apply on first boot (or after factory reset). The
//   user can long-press the milk button to launch the setup AP and
//   pick a different network at any time.
#define WIFI_SSID       ""
#define WIFI_PASSWORD   ""
