# ================================================================
#  Lyra Coffee — Next.js Web App Environment Variables
#
#  Copy to .env.local for local development.
#  Set these as Environment Variables in Vercel for production.
#  NEVER commit .env.local to version control.
# ================================================================

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://mydomain.com

# ── Supabase ─────────────────────────────────────────────────────
# Project URL (public — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://fjghhrubobqwplvokszz.supabase.co
# Anon key (public — used for client-side reads only)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key (SECRET — server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Razorpay ─────────────────────────────────────────────────────
# Key ID is used on both client and server
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
# Key Secret is SERVER-ONLY — never expose to client
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret for HMAC-SHA256 signature verification
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Admin Auth ───────────────────────────────────────────────────
# 32+ char random secret for JWT signing (generate: openssl rand -hex 32)
ADMIN_JWT_SECRET=change_me_to_a_32_plus_char_random_string_here

# ── Machine API ──────────────────────────────────────────────────
# Shared secret the ESP32/backend uses to authenticate dispense calls
MACHINE_API_SECRET=change_me_to_another_random_secret_here

# ── Rate limiting (using Supabase or in-memory) ──────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
