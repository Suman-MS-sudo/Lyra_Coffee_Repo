# ================================================================
#  Lyra Coffee Machine — Backend Environment Variables
#  Copy this file to .env and fill in your real values.
#  Never commit .env to version control.
# ================================================================

# ── Server ──────────────────────────────────────────────────────
PORT=3000

# CORS — set to your web-app's exact origin in production.
# Use * only for local development.
WEBAPP_ORIGIN=https://yourapp.com

# ── Razorpay ─────────────────────────────────────────────────────
# Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Dashboard → Settings → Webhooks → Secret
# This is used to verify the HMAC-SHA256 signature on incoming webhooks.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── MQTT Broker ───────────────────────────────────────────────────
# Public HiveMQ (no auth, demo only):
MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
#
# HiveMQ Cloud (TLS, recommended for production):
# MQTT_BROKER_URL=mqtts://your-cluster.hivemq.cloud:8883
# MQTT_USERNAME=your_hivemq_username
# MQTT_PASSWORD=your_hivemq_password
#
# Self-hosted Mosquitto (TLS):
# MQTT_BROKER_URL=mqtts://mqtt.yourserver.com:8883

# ── Pricing (in Indian Paise; 100 paise = ₹1) ────────────────────
PRICE_COFFEE_PAISE=2500
PRICE_TEA_PAISE=2000
